font-family = MonoLisa Variant
# Fallback for glyphs MonoLisa lacks (Nerd Font icons). Ghostty walks
# font-family entries in order; first font with the glyph wins.
font-family = Symbols Nerd Font Mono
font-size = 11
font-thicken = true
font-feature = ss02
font-feature = ss07
font-feature = ss11
font-feature = ss14
font-feature = ss16

